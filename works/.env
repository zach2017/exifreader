# ── AWS / LocalStack ──────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
S3_ENDPOINT=http://localstack:4566
S3_BUCKET=ocr-documents
LOCALSTACK_HOST=localstack

# ── PostgreSQL ────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=ocr_db
POSTGRES_USER=ocruser
POSTGRES_PASSWORD=ocrpass123
DATABASE_URL=postgresql://ocruser:ocrpass123@postgres:5432/ocr_db

# ── API Server ────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_BASE_URL=http://api-server:8000

# ── Lambda ────────────────────────────────────
LAMBDA_FUNCTION_NAME=ocr-trigger
